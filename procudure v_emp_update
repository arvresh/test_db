create or replace procudure v_emp_update 
as 
PRAGMA AUTONOMOUS_TRANSACTION;

TYPE V_EMPID_TAB IS TABLE OF EMPLOYEE.EMP_ID%TYPE;
TYPE V_EMPNAME_TAB IS TABLE OF EMPLOYEE.NAME%TYPE;
TYPE V_EMPSAL_TAB IS TABLE OF EMPLOYEE.SALARY%TYPE;

V_EMP_ID    :=V_EMPID_TAB;
V_EMP_NAME  :=V_EMPNAME_TAB;
V_EMP_SAL   :=V_EMPSAL_TAB;

BULK_ERROR EXCEPTION;
PRAGMA EXCEPTION_INIT(BULK_ERROR, -248311); 


BEGIN 

SELECT EMP_ID,NAME,SALARY
BULK COLLECT INTO V_EMP_ID,V_EMP_NAME,V_EMP_SAL
FROM EMP_STAGING;

BEGIN 

FORALL I IN V_EMP_ID.FIRST ..V_EMP_ID.LAST SAVE EXCEPTION 

UPDATE EMPLOYEE
SET  NAME =I.V_EMP_NAME,
SALARY = I.V_EMP_SAL
WHERE EMP_ID = I.V_EMP_ID;

EXCEPTION 

WHEN BULK_ERROR THEN
	FOR j in 1..SQL%BULK_EXCEPTIONS LOOP
	
	INSERT INTO emp_error_log
                VALUES (V_EMP_ID(SQL%BULK_EXCEPTIONS(j).ERROR_INDEX),
                    SQLERRM(-SQL%BULK_EXCEPTIONS(j).ERROR_CODE),
                    SYSDATE
                );
	
	END LOOP;
	END;
	

BEGIN 
FORALL I IN V_EMP_ID.FIRST ..V_EMP_ID.LAST SAVE EXCEPTION 

LL i IN v_emp_id.FIRST .. v_emp_id.LAST SAVE EXCEPTIONS
            INSERT INTO employee (emp_id, emp_name, salary)
            SELECT v_emp_id(i), v_emp_name(i), v_salary(i)
            FROM dual
			WHERE NOT EXISTS (SELECT 1 FROM EMPLOYEE WHERE v_emp_id =I.v_emp_id);
UPDATE EMPLOYEE
SET  NAME =I.V_EMP_NAME,
SALARY = I.V_EMP_SAL
WHERE EMP_ID = I.V_EMP_ID;

EXCEPTION
        WHEN bulk_errors THEN
            FOR j IN 1 .. SQL%BULK_EXCEPTIONS.COUNT LOOP
                INSERT INTO emp_error_log
                VALUES (
                    v_emp_id(SQL%BULK_EXCEPTIONS(j).ERROR_INDEX),
                    SQLERRM(-SQL%BULK_EXCEPTIONS(j).ERROR_CODE),
                    SYSDATE
                );
            END LOOP;
    END;
	
COMMIT;	
	
EXCEPTION
    WHEN OTHERS THEN
        INSERT INTO emp_error_log
        VALUES (NULL, SQLERRM, SYSDATE);

        COMMIT; -- commit error log even if main fails


END;
/
